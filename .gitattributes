# Force LF line endings for all text files — no CRLF anywhere in this repo.
* text=auto eol=lf

# Explicitly mark text files
*.cs        text eol=lf
*.csx       text eol=lf
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.jsx       text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf
*.csproj    text eol=lf
*.sln       text eol=lf
*.props     text eol=lf
*.targets   text eol=lf
*.editorconfig text eol=lf
*.gitattributes text eol=lf
*.gitignore text eol=lf
*.sh        text eol=lf

# Explicitly binary — never touch these
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.dll       binary
*.exe       binary
*.zip       binary
*.pfx       binary
