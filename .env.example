# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# Inverter dongle IPs are DHCP-reserved by MAC address in the router.
# Dongle serial = device serial from the LSW-3 web UI (not the inverter serial).

# Phase 1
INVERTER_0_HOST=192.168.x.x
INVERTER_0_DONGLE_SERIAL=
INVERTER_0_INVERTER_SERIAL=

# Phase 2
INVERTER_1_HOST=192.168.x.x
INVERTER_1_DONGLE_SERIAL=
INVERTER_1_INVERTER_SERIAL=

# Phase 3
INVERTER_2_HOST=192.168.x.x
INVERTER_2_DONGLE_SERIAL=
INVERTER_2_INVERTER_SERIAL=

# TimescaleDB password
DB_PASSWORD=
